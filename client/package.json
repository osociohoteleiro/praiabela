{
  "name": "praia-bela-client",
  "private": true,
  "version": "1.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "dev:pages": "wrangler pages dev -- npm run dev",
    "build": "vite build",
    "preview": "vite preview",
    "db:create": "wrangler d1 create praiabela-db",
    "db:migrate:local": "wrangler d1 execute praiabela-db --local --file=./schema.sql",
    "db:migrate:remote": "wrangler d1 execute praiabela-db --remote --file=./schema.sql",
    "db:seed:admin:local": "node scripts/seed-admin.mjs --local",
    "db:seed:admin:remote": "node scripts/seed-admin.mjs --remote",
    "deploy": "vite build && wrangler pages deploy ./dist"
  },
  "dependencies": {
    "@heroicons/react": "^2.1.1",
    "@tsndr/cloudflare-worker-jwt": "^3.1.4",
    "aws4fetch": "^1.0.20",
    "axios": "^1.6.7",
    "bcryptjs": "^2.4.3",
    "date-fns": "^3.3.1",
    "react": "^18.3.1",
    "react-datepicker": "^6.1.0",
    "react-dom": "^18.3.1",
    "react-dropzone": "^14.2.3",
    "react-hook-form": "^7.50.1",
    "react-router-dom": "^6.22.0"
  },
  "devDependencies": {
    "@types/react": "^18.2.66",
    "@types/react-dom": "^18.2.22",
    "@vitejs/plugin-react": "^4.2.1",
    "autoprefixer": "^10.4.18",
    "postcss": "^8.4.35",
    "tailwindcss": "^3.4.1",
    "vite": "^5.1.6",
    "wrangler": "^3.78.0"
  }
}
